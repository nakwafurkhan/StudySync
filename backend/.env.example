# ───────────────────────────────────────────────
# StudySync backend environment variables
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ───────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# Frontend origin (used for CORS + cookie auth)
CLIENT_URL=http://localhost:5173

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/studysync?retryWrites=true&w=majority

# Auth (Phase 2)
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── Added in later phases ───
# Phase 4 (AI schedules):
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
